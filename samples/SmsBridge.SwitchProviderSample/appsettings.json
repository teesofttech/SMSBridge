{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmsBridge": {
    "DefaultProvider": "twilio",
    "Providers": {
      "twilio": {
        "Type": "Twilio",
        "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
        "AuthToken": "YOUR_TWILIO_AUTH_TOKEN",
        "From": "+15551234567"
      },
      "vonage": {
        "Type": "Vonage",
        "ApiKey": "YOUR_VONAGE_API_KEY",
        "ApiSecret": "YOUR_VONAGE_API_SECRET",
        "From": "MyApp"
      },
      "messagebird": {
        "Type": "MessageBird",
        "AccessKey": "YOUR_MESSAGEBIRD_ACCESS_KEY",
        "From": "MyApp"
      },
      "infobip": {
        "Type": "Infobip",
        "ApiKey": "YOUR_INFOBIP_API_KEY",
        "BaseUrl": "https://YOUR_BASE_URL.api.infobip.com",
        "From": "MyApp"
      }
    }
  }
}
