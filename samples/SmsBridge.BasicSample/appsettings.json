{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmsBridge": {
    "DefaultProvider": "twilio",
    "Providers": {
      "twilio": {
        "Type": "Twilio",
        "AccountSid": "YOUR_ACCOUNT_SID",
        "AuthToken": "YOUR_AUTH_TOKEN",
        "From": "+15551234567"
      }
    }
  }
}
